# 复制此文件并重命名为 .env，填入你的真实 Key
ASR_PROVIDER=siliconflow
ASR_API_KEY=sk-your-api-key-here
ASR_URL=https://api.siliconflow.cn/v1
ASR_MODEL=FunAudioLLM/SenseVoiceSmall

